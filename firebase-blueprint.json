{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Bus": {
      "title": "Bus",
      "description": "Bus route and timing details",
      "type": "object",
      "properties": {
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "departureTime": { "type": "string" },
        "arrivalTime": { "type": "string" },
        "duration": { "type": "string" },
        "fare": { "type": "number" },
        "companyName": { "type": "string" },
        "busNumber": { "type": "string" },
        "contactNumber": { "type": "string" },
        "terminalLocation": { "type": "string" },
        "standNumber": { "type": "string" },
        "isAC": { "type": "boolean" },
        "type": { "type": "string", "enum": ["Luxury", "Executive", "Non-AC", "Standard"] }
      },
      "required": ["origin", "destination", "departureTime", "fare", "companyName"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "User submitted route information",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "departureTime": { "type": "string" },
        "fare": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "contactNumber": { "type": "string" },
        "note": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["companyName", "origin", "destination", "departureTime"]
    },
    "Career": {
      "title": "Career",
      "description": "Job application with CV submission",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "position": { "type": "string" },
        "experience": { "type": "string" },
        "cvName": { "type": "string" },
        "cvType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "mobile", "position", "experience", "cvName", "cvType"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public and private user profile data"
    },
    "buses/{busId}": {
      "schema": "Bus",
      "description": "Authenticated access for admins to manage schedules"
    },
    "contributions/{contributionId}": {
      "schema": "Contribution",
      "description": "Routes submitted by users for verification"
    },
    "feedback/{feedbackId}": {
      "schema": {
        "title": "Feedback",
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "mobile": { "type": "string" },
          "email": { "type": "string" },
          "message": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["name", "mobile", "message"]
      },
      "description": "User feedback submissions"
    },
    "complaints/{complaintId}": {
      "schema": {
        "title": "Complaint",
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "mobile": { "type": "string" },
          "email": { "type": "string" },
          "message": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["name", "mobile", "message"]
      },
      "description": "User complaint submissions"
    },
    "reports/{reportId}": {
      "schema": {
        "title": "Report",
        "type": "object",
        "properties": {
          "busId": { "type": "string" },
          "name": { "type": "string" },
          "mobile": { "type": "string" },
          "email": { "type": "string" },
          "issues": { "type": "array", "items": { "type": "string" } },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["name", "mobile", "issues"]
      },
      "description": "Reports of incorrect information"
    },
    "ratings/{ratingId}": {
      "schema": {
        "title": "Rating",
        "type": "object",
        "properties": {
          "busId": { "type": "string" },
          "userId": { "type": "string" },
          "stars": { "type": "number" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["busId", "stars"]
      },
      "description": "User ratings for buses"
    },
    "admins/{adminId}": {
      "schema": { "type": "object", "properties": { "role": { "type": "string" } } },
      "description": "List of admin users"
    },
    "careers/{careerId}": {
      "schema": "Career",
      "description": "Passenger job applications with CV attachment details"
    }
  }
}
