rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "mujahidali.webdev@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidBus(data) {
      return data.keys().hasAll(['origin', 'destination', 'departureTime', 'fare', 'companyName']) &&
             data.origin is string && data.origin.size() <= 64 &&
             data.destination is string && data.destination.size() <= 64 &&
             data.fare is number && data.fare >= 0 && data.fare <= 50000 &&
             data.companyName is string && data.companyName.size() <= 128;
    }

    function isValidContribution(data) {
      return data.keys().hasAll(['companyName', 'origin', 'destination', 'departureTime']) &&
             data.companyName is string && data.companyName.size() <= 128 &&
             data.origin is string && data.origin.size() <= 64 &&
             data.destination is string && data.destination.size() <= 64 &&
             (!('note' in data) || (data.note is string && data.note.size() <= 2000));
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // 2. Buses Collection
    match /buses/{busId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBus(incoming());
      allow update: if isAdmin() && isValidBus(incoming());
      allow delete: if isAdmin();
    }

    // 3. Contributions Collection
    match /contributions/{contribId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidContribution(incoming());
      allow delete: if isAdmin();
    }

    // 4. Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console/backend
    }
  }
}
